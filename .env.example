# 环境变量配置示例
# 复制本文件为 .env.local 并填入真实值

# OpenAI API — 用于 /api/trip/parse 的结构化行程解析
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# 生产环境默认关闭 live parse，显式设为 true 才会向公开请求暴露付费解析
TRIP_PUBLIC_LIVE_PARSE_ENABLED=false
# 单次 live parse 的最大输入长度，避免把大段文本直接烧进模型账单
TRIP_PARSE_MAX_CHARS=12000
# 单次 parse 请求体最大字节数，以及每分钟的基础请求配额
TRIP_PARSE_MAX_BODY_BYTES=32768
TRIP_PARSE_RATE_LIMIT=5
TRIP_PARSE_RATE_LIMIT_WINDOW_MS=60000

# 高德地图 Web API Key — 用于地理编码与路线矩阵
# 获取地址: https://console.amap.com/
AMAP_API_KEY=your_amap_key_here
