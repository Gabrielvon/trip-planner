// Test extractIpFromRequest function
test('extractIpFromRequest extracts IP from various headers', () => {
  // Helper function to create mock request with Headers object
  function createMockRequest(headersObj) {
    const headers = new Headers();
    for (const [key, value] of Object.entries(headersObj)) {
      headers.set(key, value);
    }
    return { headers };
  }
  
  // Test X-Forwarded-For header
  const request1 = createMockRequest({
    'x-forwarded-for': '203.0.113.195, 198.51.100.1, 192.0.2.1'
  });
  
  assert.equal(extractIpFromRequest(request1), '203.0.113.195');
  
  // Test X-Real-IP header
  const request2 = createMockRequest({
    'x-real-ip': '192.168.1.100'
  });
  
  assert.equal(extractIpFromRequest(request2), '192.168.1.100');
  
  // Test Cloudflare header
  const request3 = createMockRequest({
    'cf-connecting-ip': '10.0.0.1'
  });
  
  assert.equal(extractIpFromRequest(request3), '10.0.0.1');
  
  // Test multiple headers - should use X-Forwarded-For first
  const request4 = createMockRequest({
    'x-forwarded-for': '203.0.113.195',
    'x-real-ip': '192.168.1.100',
    'cf-connecting-ip': '10.0.0.1'
  });
  
  assert.equal(extractIpFromRequest(request4), '203.0.113.195');
  
  // Test invalid IP in X-Forwarded-For
  // If first IP is invalid, should return undefined (not fallback to proxy IPs)
  const request5 = createMockRequest({
    'x-forwarded-for': 'invalid-ip, 192.168.1.100'
  });
  
  assert.equal(extractIpFromRequest(request5), undefined);
  
  // Test no headers - should return undefined
  const request6 = createMockRequest({});
  
  assert.equal(extractIpFromRequest(request6), undefined);
  
  // Test IPv6 address
  const request7 = createMockRequest({
    'x-forwarded-for': '2001:0db8:85a3:0000:0000:8a2e:0370:7334'
  });
  
  assert.equal(extractIpFromRequest(request7), '2001:0db8:85a3:0000:0000:8a2e:0370:7334');
});

test('extractIpFromRequest handles edge cases', () => {
  // Helper function to create mock request with Headers object
  function createMockRequest(headersObj) {
    const headers = new Headers();
    for (const [key, value] of Object.entries(headersObj)) {
      headers.set(key, value);
    }
    return { headers };
  }
  
  // Test empty X-Forwarded-For
  const request1 = createMockRequest({
    'x-forwarded-for': ''
  });
  
  assert.equal(extractIpFromRequest(request1), undefined);
  
  // Test whitespace in X-Forwarded-For
  const request2 = createMockRequest({
    'x-forwarded-for': '  203.0.113.195  ,  198.51.100.1  '
  });
  
  assert.equal(extractIpFromRequest(request2), '203.0.113.195');
  
  // Test malformed header with extra commas
  const request3 = createMockRequest({
    'x-forwarded-for': '203.0.113.195,,198.51.100.1,'
  });
  
  assert.equal(extractIpFromRequest(request3), '203.0.113.195');
});